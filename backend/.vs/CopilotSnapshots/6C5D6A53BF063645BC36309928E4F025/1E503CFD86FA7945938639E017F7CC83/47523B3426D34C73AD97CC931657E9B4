using System.Text.Json;
using AirAware.Models;

namespace AirAware.Converters;

/// <summary>
/// Wandelt rohe ESP32-Payloads (JSON-Strings) in typisierte <see cref="SensorReading"/>-Objekte um.
///
/// Erwartetes JSON-Format vom ESP32 (Beispiel):
/// <code>
/// {
///   "sensor_id": "esp32-01",
///   "type": "temperature",        // "temperature" | "humidity"
///   "temp_c": 23.5,               // optional
///   "humidity_pct": 61.2,         // optional
///   "ts": 1717012345              // Unix-Epoch in Sekunden (optional)
/// }
/// </code>
/// </summary>
public static class SensorDataConverter
{
    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    /// <summary>
    /// Parst einen rohen JSON-String vom ESP32 in ein <see cref="SensorReading"/>.
    /// </summary>
    public static SensorReading Parse(string rawJson)
    {
        using var doc = JsonDocument.Parse(rawJson);
        var root = doc.RootElement;

        var reading = new SensorReading
        {
            SensorId = root.GetStringOrDefault("sensor_id") ?? "unknown",
            Type = ParseSensorType(root.GetStringOrDefault("type")),
            Timestamp = root.TryGetProperty("ts", out var ts) && ts.TryGetInt64(out var epoch)
                ? DateTimeOffset.FromUnixTimeSeconds(epoch).UtcDateTime
                : DateTime.UtcNow,
            TemperatureC = root.GetDoubleOrNull("temp_c"),
            HumidityPercent = root.GetDoubleOrNull("humidity_pct")
        };

        return reading;
    }

    /// <summary>
    /// Versucht den Payload zu parsen; gibt <c>false</c> zurück wenn das Format ungültig ist.
    /// </summary>
    public static bool TryParse(string rawJson, out SensorReading? reading)
    {
        try
        {
            reading = Parse(rawJson);
            return true;
        }
        catch
        {
            reading = null;
            return false;
        }
    }

    private static SensorType ParseSensorType(string? type) => type?.ToLowerInvariant() switch
    {
        "temperature" => SensorType.Temperature,
        "humidity" => SensorType.Humidity,
        _ => SensorType.Temperature
    };

    // ── JsonElement-Hilfsmethoden ──────────────────────────────────────

    private static string? GetStringOrDefault(this JsonElement element, string propertyName)
        => element.TryGetProperty(propertyName, out var prop) && prop.ValueKind == JsonValueKind.String
            ? prop.GetString()
            : null;

    private static double? GetDoubleOrNull(this JsonElement element, string propertyName)
    {
        if (!element.TryGetProperty(propertyName, out var prop))
            return null;

        return prop.ValueKind == JsonValueKind.Number && prop.TryGetDouble(out var value)
            ? value
            : null;
    }
}
