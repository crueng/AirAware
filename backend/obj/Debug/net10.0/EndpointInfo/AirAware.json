{
  "openapi": "3.0.4",
  "info": {
    "title": "AirAware",
    "version": "1.0"
  },
  "paths": {
    "/api/SensorData/latest": {
      "get": {
        "tags": [
          "SensorData"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/SensorData/history": {
      "get": {
        "tags": [
          "SensorData"
        ],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": {
              "$ref": "#/components/schemas/SensorType"
            }
          },
          {
            "name": "count",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SensorReading"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/SensorData/report": {
      "get": {
        "tags": [
          "SensorData"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SensorReport"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorReport"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorReport"
                }
              }
            }
          }
        }
      }
    },
    "/api/SensorData/thresholds": {
      "get": {
        "tags": [
          "SensorData"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlertThreshold"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlertThreshold"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AlertThreshold"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "SensorData"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertThreshold"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AlertThreshold"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AlertThreshold"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AlertThreshold"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertThreshold"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlertThreshold"
                }
              }
            }
          }
        }
      }
    },
    "/api/SensorData/alerts": {
      "get": {
        "tags": [
          "SensorData"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/WeatherForecast": {
      "get": {
        "tags": [
          "WeatherForecast"
        ],
        "operationId": "GetWeatherForecast",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeatherForecast"
                  }
                }
              }
            }
          }
        }
      }
    }
