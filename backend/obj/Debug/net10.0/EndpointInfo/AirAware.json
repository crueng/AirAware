  "components": {
    "schemas": {
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "reading": {
            "$ref": "#/components/schemas/SensorReading"
          },
          "threshold": {
            "$ref": "#/components/schemas/AlertThreshold"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "triggeredAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "AlertThreshold": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/SensorType"
          },
          "metricName": {
            "type": "string",
            "nullable": true
          },
          "minValue": {
            "type": "number",
            "format": "double"
          },
          "maxValue": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "SensorReading": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "sensorId": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "$ref": "#/components/schemas/SensorType"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "temperatureC": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "temperatureF": {
            "type": "number",
            "format": "double",
            "nullable": true,
            "readOnly": true
          },
          "humidityPercent": {
            "type": "number",
            "format": "double",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SensorReport": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "format": "date-time"
          },
          "to": {
            "type": "string",
            "format": "date-time"
          },
          "totalReadings": {
            "type": "integer",
            "format": "int32"
          },
          "avgTemperatureC": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "minTemperatureC": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "maxTemperatureC": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "avgHumidityPercent": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "minHumidityPercent": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "maxHumidityPercent": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "alertCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "SensorType": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "SensorData"
    },
    {
      "name": "WeatherForecast"
    }
  ]
}